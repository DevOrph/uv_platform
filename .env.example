# ============================================================
# Modèle de configuration — copier en .env et remplir
#   Local  : cp .env.example .env  (valeurs XAMPP ci-dessous)
#   Prod   : déposer un .env à la racine du site Hostinger
#            (voir .env.production conservé en local, hors git)
# ============================================================

# Base de données
#   Local XAMPP : DB_HOST=127.0.0.1, DB_USER=root, DB_PASS vide, DB_NAME=uvcoding
#   Hostinger   : DB_HOST=localhost, utilisateur/base au format u641337841_xxx
DB_HOST=127.0.0.1
DB_NAME=uvcoding
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SendGrid : la clé API n'est PAS lue ici — elle est stockée en base,
# table `parametres`, cle = 'sendgrid_api_key' (lue par includes/sendgrid_helper.php).
# Elle arrive automatiquement avec l'import de uvcoding.sql.

# Institution
INSTITUTION_ID=UAS

# API mobile v2 (JWT) — générer avec : php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=changez-moi-valeur-aleatoire-forte
